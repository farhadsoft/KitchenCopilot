@using Kitchen.Shared.Models
@using Kitchen.Web.Services
@inject BrowserLlmService LlmService
@implements IAsyncDisposable

<div class="ios-card">
    @if (_streaming)
    {
        <div class="ios-streaming-indicator">
            <span class="ios-pulse-dot"></span>
            Chef is thinking…
        </div>
    }

    @if (_error is not null)
    {
        <p class="ios-error">⚠ @_error</p>
    }
    else if (!string.IsNullOrEmpty(_recipe))
    {
        <div class="ios-recipe-content">
            @((MarkupString)_recipe)
        </div>
    }
    else if (!_streaming)
    {
        <p class="ios-placeholder">Your recipe will appear here.</p>
    }
</div>

@code {
    [Parameter] public List<Ingredient> Ingredients { get; set; } = [];
    [Parameter] public bool Trigger { get; set; }

    private string _recipe = string.Empty;
    private string? _error;
    private bool _streaming;
    private CancellationTokenSource _cts = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Trigger && Ingredients.Count > 0)
            await StartStreamingAsync();
    }

    private async Task StartStreamingAsync()
    {
        await _cts.CancelAsync();
        _cts = new CancellationTokenSource();
        _recipe = string.Empty;
        _error = null;
        _streaming = true;

        var sb = new System.Text.StringBuilder();

        try
        {
            await foreach (var token in LlmService.StreamAsync(Ingredients, _cts.Token))
            {
                sb.Append(System.Net.WebUtility.HtmlEncode(token));
                _recipe = sb.ToString().Replace("\n", "<br/>");
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _streaming = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
