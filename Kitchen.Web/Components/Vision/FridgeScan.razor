@using Kitchen.Shared.Models
@using Kitchen.Web.Services
@inject YoloInferenceService YoloService
@inject IJSRuntime JS

<div class="kc-card">
    <h2 class="kc-title" style="margin-bottom:16px;">Scan Your Fridge</h2>

    <div class="kc-control-row">
        <label class="kc-btn-primary" style="cursor:pointer;">
            📷 Upload Photo
            <InputFile OnChange="OnFileSelected" accept="image/*" style="display:none" />
        </label>
        <button class="kc-btn-secondary" @onclick="StartCamera" disabled="@_cameraActive">
            🎥 Camera
        </button>
    </div>

    @if (_cameraActive)
    {
        <video id="camera-feed" autoplay playsinline class="kc-camera-feed" style="margin-bottom:12px;"></video>
        <button class="kc-btn-primary" @onclick="CaptureFrame">Capture</button>
    }

    <canvas id="image-canvas" hidden></canvas>

    @if (_loading)
    {
        <div class="kc-streaming-indicator" style="margin-top:12px;">
            <span class="kc-pulse-dot"></span>
            Detecting ingredients…
        </div>
    }

    @if (DetectedIngredients.Count > 0)
    {
        <div class="kc-divider"></div>
        <p class="kc-section-header">Detected Ingredients</p>
        <div class="kc-chips">
            @foreach (var ing in DetectedIngredients)
            {
                <span class="kc-chip">@ing.Name <small>@(ing.Confidence.ToString("P0"))</small></span>
            }
        </div>
        <button class="kc-btn-primary" style="margin-top:8px;" @onclick="OnGenerateRecipe">
            ✨ Generate Recipe
        </button>
    }
</div>

@code {
    [Parameter] public EventCallback<List<Ingredient>> OnIngredientsDetected { get; set; }
    [Parameter] public EventCallback OnGenerateClicked { get; set; }

    public List<Ingredient> DetectedIngredients { get; private set; } = [];

    private bool _loading;
    private bool _cameraActive;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _loading = true;
        StateHasChanged();
        try
        {
            await using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await RunInferenceAsync(ms.ToArray(), e.File.ContentType);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartCamera()
    {
        _cameraActive = true;
        StateHasChanged();
        await Task.Yield(); // wait for Blazor to render the <video> element before calling JS
        await JS.InvokeVoidAsync("kitchenCamera.start", "camera-feed");
    }

    private async Task CaptureFrame()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            // Capture while the <video> element is still in the DOM, then stop the stream
            var pixelData = await JS.InvokeAsync<PixelCapture>("kitchenCamera.capture", "camera-feed", "image-canvas");
            _cameraActive = false;
            _ = JS.InvokeVoidAsync("kitchenCamera.stop"); // fire-and-forget after capture
            StateHasChanged();
            if (pixelData is null) return;
            DetectedIngredients = await YoloService.DetectAsync(pixelData.Rgba, pixelData.Width, pixelData.Height, default);
            await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunInferenceAsync(byte[] imageBytes, string contentType = "image/jpeg")
    {
        var pixelData = await JS.InvokeAsync<PixelCapture>("kitchenCamera.decodeImage", imageBytes, "image-canvas", contentType);
        DetectedIngredients = await YoloService.DetectAsync(pixelData.Rgba, pixelData.Width, pixelData.Height, default);
        await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
    }

    private async Task OnGenerateRecipe() => await OnGenerateClicked.InvokeAsync();

    private record PixelCapture(int[] Rgba, int Width, int Height);
}
