@using Kitchen.Shared.Models
@using Kitchen.Web.Services
@inject YoloInferenceService YoloService
@inject IJSRuntime JS

<div>
    @if (_cameraActive)
    {
        <div class="kc-camera-card" style="padding:16px;">
            <video id="camera-feed" autoplay playsinline class="kc-camera-feed" style="margin-bottom:12px;"></video>
            <button class="kc-btn-primary" @onclick="CaptureFrame">Capture</button>
        </div>
    }
    else
    {
        <div class="kc-camera-card">
            <div class="kc-camera-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                    <circle cx="12" cy="13" r="4"/>
                </svg>
            </div>
            <p class="kc-camera-hint">Point at your ingredients</p>
        </div>
    }

    <canvas id="image-canvas" hidden></canvas>

    @if (_loading)
    {
        <div class="kc-streaming-indicator" style="margin-bottom:16px;">
            <span class="kc-pulse-dot"></span>
            Detecting ingredients…
        </div>
    }
    else if (!_cameraActive)
    {
        <div class="kc-control-row" style="margin-bottom:16px;">
            <label class="kc-btn-primary" style="cursor:pointer; display:flex; align-items:center; gap:6px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M10.3 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10l-3.1-3.1a2 2 0 0 0-2.814.014L6 21"/>
                    <path d="m14 19 3-3 3 3"/>
                    <path d="M17 22v-6"/>
                    <circle cx="9" cy="9" r="2"/>
                </svg>
                Photo
                <InputFile OnChange="OnFileSelected" accept="image/*" style="display:none" />
            </label>
            <button class="kc-btn-secondary" @onclick="StartCamera">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                    <circle cx="12" cy="13" r="4"/>
                </svg>
                Camera
            </button>
        </div>
    }

    <div>
        <div class="kc-section-row">
            <p class="kc-section-header" style="padding-bottom:0;">Detected Items</p>
            <span class="kc-badge-edge">YOLO26 EDGE</span>
        </div>

        <div class="kc-chips">
            @foreach (var ing in DetectedIngredients)
            {
                <span class="kc-chip kc-chip--removable" @onclick="() => RemoveIngredient(ing)">
                    @ing.Name <small>@(ing.Confidence.ToString("P0"))</small>
                    <span class="kc-chip-remove" aria-label="Remove">×</span>
                </span>
            }
            @if (DetectedIngredients.Count == 0)
            {
                <p class="kc-empty-state-text" style="margin:0;">Fridge is empty — type below to add</p>
            }
            <input class="kc-chip-input" placeholder="Add ingredient…"
                   @bind="_newIngredientName" @bind:event="oninput"
                   @onkeydown="OnAddKeyDown" />
        </div>

        @if (DetectedIngredients.Count > 0)
        {
            <button class="kc-btn-primary" style="margin-top:8px;" @onclick="OnGenerateRecipe">
                ✨ Generate Recipe
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback<List<Ingredient>> OnIngredientsDetected { get; set; }
    [Parameter] public EventCallback OnGenerateClicked { get; set; }

    public List<Ingredient> DetectedIngredients { get; private set; } = [];

    private bool _loading;
    private bool _cameraActive;
    private string _newIngredientName = string.Empty;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        // Read bytes BEFORE StateHasChanged() — setting _loading=true unmounts InputFile,
        // which invalidates the Blazor JS file reference (_blazorFilesById becomes null).
        byte[] imageBytes;
        var contentType = e.File.ContentType;
        await using (var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
        {
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            imageBytes = ms.ToArray();
        }

        _loading = true;
        StateHasChanged();
        try
        {
            await RunInferenceAsync(imageBytes, contentType);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartCamera()
    {
        _cameraActive = true;
        StateHasChanged();
        await Task.Yield(); // wait for Blazor to render the <video> element before calling JS
        await JS.InvokeVoidAsync("kitchenCamera.start", "camera-feed");
    }

    private async Task CaptureFrame()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            // Capture while the <video> element is still in the DOM, then stop the stream
            var pixelData = await JS.InvokeAsync<PixelCapture>("kitchenCamera.capture", "camera-feed", "image-canvas");
            _cameraActive = false;
            _ = JS.InvokeVoidAsync("kitchenCamera.stop"); // fire-and-forget after capture
            StateHasChanged();
            if (pixelData is null) return;
            DetectedIngredients = await YoloService.DetectAsync(pixelData.Rgba, pixelData.Width, pixelData.Height, default);
            await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunInferenceAsync(byte[] imageBytes, string contentType = "image/jpeg")
    {
        var pixelData = await JS.InvokeAsync<PixelCapture>("kitchenCamera.decodeImage", imageBytes, "image-canvas", contentType);
        DetectedIngredients = await YoloService.DetectAsync(pixelData.Rgba, pixelData.Width, pixelData.Height, default);
        await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
    }

    private async Task AddIngredient()
    {
        var name = _newIngredientName.Trim();
        if (string.IsNullOrEmpty(name)) return;
        DetectedIngredients = [.. DetectedIngredients, new Ingredient(name, 1f)];
        _newIngredientName = string.Empty;
        await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
    }

    private async Task OnAddKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddIngredient();
    }

    private async Task RemoveIngredient(Ingredient ing)
    {
        DetectedIngredients = DetectedIngredients.Where(i => i != ing).ToList();
        await OnIngredientsDetected.InvokeAsync(DetectedIngredients);
    }

    private async Task OnGenerateRecipe() => await OnGenerateClicked.InvokeAsync();

    private record PixelCapture(int[] Rgba, int Width, int Height);
}
