@page "/"
@using Kitchen.Shared.Models
@using Kitchen.Web.Components
@using Kitchen.Web.Components.Vision

<PageTitle>Kitchen Copilot</PageTitle>

<div class="kc-page">
    <header class="kc-page-header">
        <div class="kc-header-row">
            <div>
                <h1 class="kc-display-title">Kitchen</h1>
                <p class="kc-subtitle">Captain AI &bull; Local Edge</p>
            </div>
            <button class="kc-btn-icon" aria-label="Settings" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
                    <path d="M12 2v2M12 20v2M2 12h2M20 12h2"/>
                    <path d="m4.22 4.22 1.42 1.42M18.36 18.36l1.42 1.42M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </svg>
            </button>
        </div>
    </header>

    <div class="kc-page-body">
        <FridgeScan
            OnIngredientsDetected="HandleIngredients"
            OnGenerateClicked="TriggerGeneration" />

        <div style="margin-top:20px;">
            <RecipeDisplay
                Ingredients="_ingredients"
                Trigger="_generateTrigger" />
        </div>
    </div>
</div>

@code {
    private List<Ingredient> _ingredients = [];
    private bool _generateTrigger;

    private void HandleIngredients(List<Ingredient> ingredients)
    {
        _ingredients = ingredients;
        _generateTrigger = false;
    }

    private void TriggerGeneration()
    {
        _generateTrigger = true;
    }
}
