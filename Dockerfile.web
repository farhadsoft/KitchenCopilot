FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Python is required by Emscripten during wasm-tools native compilation
RUN apt-get update && apt-get install -y --no-install-recommends python3 \
    && ln -s /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# Copy global.json first so the correct SDK band is active when installing workloads
COPY global.json ./
RUN dotnet workload install wasm-tools

COPY Kitchen.Shared/Kitchen.Shared.csproj Kitchen.Shared/
COPY Kitchen.Web/Kitchen.Web.csproj       Kitchen.Web/
RUN dotnet restore Kitchen.Web/Kitchen.Web.csproj

COPY Kitchen.Shared/ Kitchen.Shared/
COPY Kitchen.Web/    Kitchen.Web/

RUN dotnet publish Kitchen.Web/Kitchen.Web.csproj \
    -c Release \
    -o /app/publish

# In .NET 10 Blazor WASM with OverrideHtmlAssetPlaceholders=true, the SDK
# replaces #[.{fingerprint}] placeholders in script tags but leaves the
# importmap {} empty, so blazor.webassembly.js tries to fetch the unhashed
# dotnet.js literally and gets a 404.  Create a re-export shim if missing.
RUN HASH=$(ls /app/publish/wwwroot/_framework/ | grep -E '^dotnet\.[a-z0-9]+\.js$' | head -1) && \
    if [ ! -f /app/publish/wwwroot/_framework/dotnet.js ] && [ -n "$HASH" ]; then \
      printf 'export * from "./%s";\nexport { default } from "./%s";\n' "$HASH" "$HASH" \
        > /app/publish/wwwroot/_framework/dotnet.js && \
      echo "Created dotnet.js shim -> $HASH"; \
    fi

FROM nginx:1.27-alpine AS runtime

COPY --from=build /app/publish/wwwroot /usr/share/nginx/html
COPY docker/web/default.conf.template /etc/nginx/templates/default.conf.template

ENV HTTP_PORTS=8080
EXPOSE 8080
